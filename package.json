{
  "name": "moodle-pdf-downloader",
  "version": "1.0.0",
  "description": "Simple TypeScript script to download PDFs from Moodle after login",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "download": "ts-node src/index.ts",
    "summarize": "ts-node src/pdf-summarizer.ts",
    "test-summarize": "ts-node src/test-summarizer.ts",
    "daily": "npm run download && npm run summarize"
  },
  "keywords": [
    "moodle",
    "pdf",
    "downloader",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@sap-ai-sdk/core": "^2.0.0",
    "@sap-ai-sdk/orchestration": "^2.0.0",
    "dotenv": "^17.2.3",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.4.149"
  }
}
